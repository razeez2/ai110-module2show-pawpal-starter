classDiagram
    %% PawPal+ — pet care planning assistant (matches final implementation)
    %% Owner has many Pet; Pet has many Task; Scheduler reasons across them via the Owner.

    class Task {
        +str description
        +str time
        +str frequency
        +bool completed
        +date due_date
        +mark_complete() void
        +mark_incomplete() void
        +next_occurrence() Task
        +__str__() str
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task Task) void
        +remove_task(task Task) void
        +pending_tasks() list~Task~
    }

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet Pet) void
        +remove_pet(pet Pet) void
        +get_all_tasks() list~Task~
    }

    class Scheduler {
        +Owner owner
        +get_all_tasks() list~Task~
        +tasks_by_pet() dict
        +pending_tasks() list~Task~
        +tasks_for_frequency(frequency str) list~Task~
        +tasks_for_pet(name str) list~Task~
        +organize() list~Task~
        +todays_plan(day date) list~Task~
        +complete_task(task Task) Task
        +find_conflicts() list~str~
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler "1" --> "1" Owner : plans for
    Task ..> Task : next_occurrence creates
